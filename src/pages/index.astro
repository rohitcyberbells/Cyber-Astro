    <!--------  HERO ------------>
    <section class="hero">
        <div class="hero-container">
            <div class="hero-content">
                <h1 class="hero-title">
                    <span class="hero-word"> Turn Your</span>
                    <span class="hero-word"><span class="red-text"> App </span></span>
                    <span class="hero-word"> Idea </span><br>
                    <span class="hero-word"> Into Reality</span>
                </h1>

                <div class="hero-cards-wrapper">
                    <div class="cards">
                        <div class="card1 ph-card"><img src="assets/Images/Hero/flock.jpg" alt="Card 1"></div>
                        <div class="card2 ph-card"><img src="assets/Images/Hero/SafeGrow.jpg" alt="Card 2"></div>
                        <div class="card3 ph-card"><img src="assets/Images/Hero/Coffee.jpg" alt="Card 3"></div>
                        <div class="card4 ph-card"><img src="assets/Images/Hero/ugive.jpg" alt="Card 4"></div>
                        <div class="card5 ph-card"><img src="assets/Images/Hero/Browns.jpg" alt="Card 5"></div>
                        <div class="card6 ph-card"><img src="assets/Images/Hero/OnCoffee.png" alt="Card 6"></div>
                        <div class="card7 ph-card"><img src="assets/Images/Hero/Splash.jpg" alt="Card 7"></div>
                    </div>
                </div>

                <p class="hero-para"> Creating high-quality mobile applications that blend aesthetic design with
                    powerful technology,<br> seamless functionality, and exceptional user experiences. </p>

                <div class="hero-btn-wrapper">
                    <button class="hero-btn"
                        onclick="Calendly.initPopupWidget({url: 'https://calendly.com/cyberbells/new-meeting?hide_gdpr_banner=1&month=2026-07'});return false;">Book
                        Your Strategy Session</button>
                    <button class="readmore-btn" id="openQuoteModalBtn">Request Free Quote</button>
                </div>
            </div>
        </div>
    </section>

    <!------- SECTION 2  --------->
    <section class="diagonal-card">
        <div class="diagonal-card-container">
            <div class="dc-left">
                <h2 class="diagonal-title">
                    <span class="diagonal-word"> Imagine. </span>
                    <span class="diagonal-word"> Build.</span><br>
                    <span class="diagonal-word"><span class="red-text">Launch.</span>
