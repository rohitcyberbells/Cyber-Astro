<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Primary Meta Tags -->
    <title>CyberBells | High-Quality Mobile Application Development</title>
    <meta name="title" content="CyberBells | High-Quality Mobile Application Development">
    <meta name="description" content="CyberBells turns your app idea into reality. We design, develop, test, and publish your mobile app on the App Store and Google Play in as little as 90 days.">
    <meta name="keywords" content="mobile app development, iOS app, Android app, app design, custom software, CyberBells">
    <meta name="author" content="CyberBells">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cyberbells.com/">
    <meta property="og:title" content="CyberBells | High-Quality Mobile Application Development">
    <meta property="og:description" content="CyberBells turns your app idea into reality. We design, develop, test, and publish your mobile app on the App Store and Google Play in as little as 90 days.">
    <meta property="og:image" content="/assets/Logo/CyberLogo.png">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://cyberbells.com/">
    <meta property="twitter:title" content="CyberBells | High-Quality Mobile Application Development">
    <meta property="twitter:description" content="CyberBells turns your app idea into reality. We design, develop, test, and publish your mobile app on the App Store and Google Play.">
    <meta property="twitter:image" content="/assets/Logo/CyberLogo.png">

    <link rel="canonical" href="https://cyberbells.com/">

    <!-- External Assets -->
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
    <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js" defer></script>
</head>

<body>
