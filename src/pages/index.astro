    <!----- Section 8 Story Telling  --------->
    <section class="storytelling">
        <div class="storytelling-container">
            <div class="storytelling-header">
                <span class="storytelling-header-word">STORY</span>
                <span class="storytelling-header-word"><span class="text-blue">TELLING</span></span>
            </div>

            <h2 class="storytelling-title">
                <span class="storytelling-word">Ideas we</span><span class="storytelling-word"> turned
                    into</span><br>
                <span class="storytelling-word"> Mobile </span><span class="storytelling-word"> Experiences </span>
            </h2>

            <div class="story-cards" id="storyCards">
                <!-- Left Card -->
                <div class="story-card card-white">
                    <div class="card-top-bar">
                        <div class="play-btn">
                            <span class="play-icon">▶</span>
                        </div>
                        <div class="author-bubble author-blue">@Featured</div>
                    </div>
                    <div class="card-visual-placeholder">
                        <Image src={images['/src/assets/Images/TalkBrush.png']?.default} alt="TalkBrush.png" loading="lazy" decoding="async" />
                    </div>
                    <div class="card-info">
                        <h3>Talk Brush</h3>
                        <p>TalkBrush transforms live conversations by letting every listener hear the speaker
                            in a natural English accent they're comfortable with. From global meetings to live
                            events, it removes accent barriers so every conversation feels familiar, effortless,
                            and truly connected.</p>
                        <button class="card-pill-btn">View Case Study </button>
                    </div>
                </div>

                <!-- Right Card -->
                <div class="story-card card-mixed">
                    <div class="card-top-bar">
                        <div class="play-btn">
                            <span class="play-icon">▶</span>
                        </div>
                        <div class="author-bubble author-blue">@Trending</div>
                    </div>
