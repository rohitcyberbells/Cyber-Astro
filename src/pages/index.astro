    <!-- Quote Modal -->
    <div id="quoteModal" class="quote-modal">
        <div class="quote-modal-content">
            <span class="quote-close-btn">&times;</span>
            <h2 class="quote-modal-title">Request a Free Quote</h2>
            <p class="quote-modal-subtitle">Tell us about your project and we'll get back to you shortly.</p>

            <form id="quoteForm" class="quote-form">
                <div class="form-row">
                    <div class="form-group">
                        <label for="firstName">First Name</label>
                        <input type="text" id="firstName" name="firstName" placeholder="John">
                        <span class="error-msg" id="err-firstName">First name is required</span>
                    </div>
                    <div class="form-group">
                        <label for="lastName">Last Name</label>
                        <input type="text" id="lastName" name="lastName" placeholder="Doe">
                        <span class="error-msg" id="err-lastName">Last name is required</span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="john@example.com">
                    <span class="error-msg" id="err-email">Valid email is required</span>
                </div>

                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" rows="4"
                        placeholder="Tell us about your app idea..."></textarea>
                    <span class="error-msg" id="err-message">Message is required</span>
                </div>

                <button type="submit" class="quote-submit-btn" id="quoteSubmitBtn">
                    <span class="btn-text">Submit Request</span>
                    <span class="btn-loader" style="display: none;">Wait...</span>
                </button>

                <div class="success-msg" id="quoteSuccessMsg" style="display: none;">
                    Your request has been sent successfully! We'll be in touch soon.
                </div>
            </form>
        </div>
