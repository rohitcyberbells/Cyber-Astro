---

import { Image } from 'astro:assets';
const images = import.meta.glob('/src/assets/**/*.{jpeg,jpg,png,gif,webp,svg}', { eager: true });
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Primary Meta Tags -->
    <title>CyberBells | High-Quality Mobile Application Development</title>
    <meta name="title" content="CyberBells | High-Quality Mobile Application Development">
    <meta name="description" content="CyberBells turns your app idea into reality. We design, develop, test, and publish your mobile app on the App Store and Google Play in as little as 90 days.">
    <meta name="keywords" content="mobile app development, iOS app, Android app, app design, custom software, CyberBells">
    <meta name="author" content="CyberBells">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cyberbells.com/">
    <meta property="og:title" content="CyberBells | High-Quality Mobile Application Development">
    <meta property="og:description" content="CyberBells turns your app idea into reality. We design, develop, test, and publish your mobile app on the App Store and Google Play in as little as 90 days.">
    <meta property="og:image" content={"https://cyberbells.com" + (images['/src/assets/Logo/CyberLogo.png']?.default?.src || "")}>

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://cyberbells.com/">
    <meta property="twitter:title" content="CyberBells | High-Quality Mobile Application Development">
    <meta property="twitter:description" content="CyberBells turns your app idea into reality. We design, develop, test, and publish your mobile app on the App Store and Google Play.">
    <meta property="twitter:image" content={"https://cyberbells.com" + (images['/src/assets/Logo/CyberLogo.png']?.default?.src || "")}>

    <link rel="canonical" href="https://cyberbells.com/">

    <!-- External Assets -->
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
    <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js" defer></script>
<meta property="og:site_name" content="CyberBells">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>

<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <Image src={images['/src/assets/Logo/CyberLogo.png']?.default} alt="CyberLogo" loading="lazy" decoding="async" />
            </div>
        </div>
    </nav>
    <!--------  HERO ------------>
    <section class="hero">
        <div class="hero-container">
            <div class="hero-content">
                <h1 class="hero-title">
                    <span class="hero-word">Turn Your&nbsp;</span>
                    <span class="hero-word"><span class="red-text">App&nbsp;</span></span>
                    <span class="hero-word">Idea</span><br>
                    <span class="hero-word">Into Reality</span>
                </h1>

                <div class="hero-cards-wrapper">
                    <div class="cards">
                        <div class="card1 ph-card"><Image src={images['/src/assets/Images/Hero/flock.jpg']?.default} alt="Flock App Interface" width="300" height="500"  /></div>
                        <div class="card2 ph-card"><Image src={images['/src/assets/Images/Hero/SafeGrow.jpg']?.default} alt="SafeGrow Interface" width="300" height="500"  /></div>
                        <div class="card3 ph-card"><Image src={images['/src/assets/Images/Hero/Coffee.jpg']?.default} alt="Coffee App UI" width="300" height="500"  /></div>
                        <div class="card4 ph-card"><Image src={images['/src/assets/Images/Hero/ugive.jpg']?.default} alt="Ugive App Preview" width="300" height="500"  /></div>
                        <div class="card5 ph-card"><Image src={images['/src/assets/Images/Hero/Browns.jpg']?.default} alt="Browns E-Commerce UI" width="300" height="500"  /></div>
                        <div class="card6 ph-card"><Image src={images['/src/assets/Images/Hero/OnCoffee.png']?.default} alt="OnCoffee Delivery App" width="300" height="500"  /></div>
                        <div class="card7 ph-card"><Image src={images['/src/assets/Images/Hero/Splash.jpg']?.default} alt="Splash Analytics Dashboard" width="300" height="500" fetchpriority="high" loading="eager" decoding="async"  /></div>
                    </div>
                </div>

                <p class="hero-para"> Creating high-quality mobile applications that blend aesthetic design with
                    powerful technology,<br> seamless functionality, and exceptional user experiences. </p>

                <div class="hero-btn-wrapper">
                    <button class="hero-btn"
                        onclick="Calendly.initPopupWidget({url: 'https://calendly.com/cyberbells/new-meeting?hide_gdpr_banner=1'});return false;">Book
                        Your Strategy Session</button>
                    <button class="readmore-btn" id="openQuoteModalBtn">Request Free Quote</button>
                </div>
            </div>
        </div>
    </section>

    <!------- SECTION 2  --------->
    <section class="diagonal-card">
        <div class="diagonal-card-container">
            <div class="dc-left">
                <h2 class="diagonal-title">
                    <span class="diagonal-word"> Imagine. </span>
                    <span class="diagonal-word"> Build.</span><br>
                    <span class="diagonal-word"><span class="red-text">Launch.</span>
                        <span class="diagonal-word"> Your</span>
                        <span class="diagonal-word"> Next</span></span><br>
                    <span class="diagonal-word">Mobile App.</span>

                </h2>

                <p class="diagonal-para">
                    <span class="diagonal-word">From idea to launch in as little as 90 days.</span><br>
                    <span class="diagonal-word"> We design, develop, test, and publish </span><br>
                    <span class="diagonal-word"> your app on the App Store and Google Play</span><br>
                    <span class="diagonal-word">while keeping you involved every step of the way.</span>
                </p>

                <div class="diagonal-btn-wrapper">
                    <button class="diagonal-join-btn">Join for $9.99/m</button>
                    <button class="diagonal-readmore-btn">Read more</button>
                </div>
            </div>

            <div class="dc-right">
                <div class="dc-cards-wrapper">
                    <div class="dc-card dcc1" style="opacity: 0;"></div>
                    <div class="dc-card dcc2" style="opacity: 0;"></div>
                    <div class="dc-card dcc3" style="opacity: 0;"></div>
                    <div class="dc-card dcc4" style="opacity: 0;"></div>
                    <div class="dc-card dcc5" style="opacity: 0;"></div>

                    <div class="dc-chat-bubble dc-bubble-a">Design</div>
                    <div class="dc-chat-bubble dc-bubble-b">Development</div>
                    <div class="dc-chat-bubble dc-bubble-c">Launch</div>
                </div>
            </div>
        </div>
    </section>

    <!---------- Section 3 Gateway ------------->
    <section class="gateway">
        <div class="gateway-container">
            <div class="gateway-header">
                <div class="gateway-text">
                    <div class="gateway-heading">
                        <span class="gateway-word">INDUSTRIES</span> <span class="gateway-word">WE</span> <span
                            class="gateway-word">SERVE</span>
                    </div>
                    <div class="gateway-title">
                        <span class="gateway-word">Mobile Apps</span> <span class="gateway-word">for</span><br>
                        <span class="gateway-word">Every</span> <span class="gateway-word">Industry.</span>
                    </div>
                </div>
                <div class="gateway-author">
                    <div class="gateway-author-bubble"><span class="gateway-word">@Swipe</span></div>
                </div>
            </div>

            <div class="gateway-img-wrapper">
                <div class="gateway-carousel">
                    <Image class="carousel-slide active" src={images['/src/assets/Images/Banner images/Fintech.png']?.default} alt="Fintech" loading="lazy" decoding="async" />
                    <Image class="carousel-slide" src={images['/src/assets/Images/Banner images/Logistics.png']?.default} alt="Logistics" loading="lazy" decoding="async" />
                    <Image class="carousel-slide" src={images['/src/assets/Images/Banner images/Ecommerce.png']?.default} alt="Ecommerce" loading="lazy" decoding="async" />
                    <Image class="carousel-slide" src={images['/src/assets/Images/Banner images/Management.png']?.default} alt="ManagementSystem" loading="lazy" decoding="async" />
                    <Image class="carousel-slide" src={images['/src/assets/Images/Banner images/Healthcare (2).png']?.default} alt="Healthcare" loading="lazy" decoding="async" />

                </div>

                <div class="gateway-bottom-right">
                    <button class="arrow-btn prev-btn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="15 18 9 12 15 6"></polyline>
                        </svg>
                    </button>
                    <button class="arrow-btn next-btn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!----------- Section 4 Marquee Section --------------->
    <section class="marquee">
        <div class="marquee-container">
            <div class="marquee-header">
                <div class="marquee-text">
                    <h2 class="marquee-title">
                        <span class="marquee-word">One App.</span><br>
                        <span class="marquee-word">
                            <span class="red-text">Every Platform</span></span>

                    </h2>
                    <p class="marquee-para">
                        From smartphones to tablets, wearables, and the web, we build apps that deliver a seamless
                        experience across every screen.

                    </p>
                </div>
            </div>

            <div class="marquee-logos-wrapper">
                <div class="marquee-track">
                    <div class="logo-item">IOS</div>
                    <div class="logo-item">ANDROID</div>
                    <div class="logo-item">TABLETS</div>
                    <div class="logo-item">FOLDABLES</div>
                    <div class="logo-item">CROSS-PLATFORM</div>
                    <div class="logo-item">TV APPS</div>

                    <div class="logo-item">IOS</div>
                    <div class="logo-item">ANDROID</div>
                    <div class="logo-item">TABLETS</div>
                    <div class="logo-item">FOLDABLES</div>
                    <div class="logo-item">CROSS-PLATFORM</div>
                    <div class="logo-item">TV APPS</div>

                    <div class="logo-item">IOS</div>
                    <div class="logo-item">ANDROID</div>
                    <div class="logo-item">TABLETS</div>
                    <div class="logo-item">FOLDABLES</div>
                    <div class="logo-item">CROSS-PLATFORM</div>
                    <div class="logo-item">TV APPS</div>
                </div>
                <!-- Fading edges -->
                <div class="fade-left"></div>
                <div class="fade-right"></div>
            </div>
        </div>
    </section>

<!-------- Section 5 MarketPlace Place -------->
<div class="marketplace">
    <div class="marketplace-container" style="position: relative;">

        <div class="marketplace-title"
            style="position: relative; z-index: 10; padding-bottom: 0; margin-bottom: 0; pointer-events: none;">
            <div class="mp-text">
                Designed for people. Built for businesses. Engineered to grow.
                Every screen, every interaction, and every feature is crafted
                to deliver an experience your users will remember.
            </div>
        </div>

        <div id="particle-wave-container"></div>
    </div>
</div>
